<div class="flex flex-col items-center w-full gap-8">

<h1 class="text-4xl mb-10 font-bold bg-red-500 text-white p-4 rounded"><%= @user.username %></h1>



<% @user.links.each do |link| %>
<%= link_to link.url, class:"max-w-sm w-full" do %>
<div class="max-w-sm w-full text-2xl bg-gray-500 hover:bg-gray-800 text-white text-center py-4 ">
  <%= link.name %>
</div>
    <% end %>
    <% end %>
</div>